# Shared password the editor (and you) use to log in.
APP_PASSWORD=change-me-to-something-only-you-two-know

# Long random string — keeps login cookies valid across restarts.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=

# Optional: Hyperframes version to render with (default 0.6.97).
# HF_VERSION=0.6.97

# Optional: frame rate and quality (draft | standard | high). Defaults: 30 / high.
# FPS=30
# QUALITY=high

# Optional: port inside the container (Traefik points here). Default 8080.
# PORT=8080
