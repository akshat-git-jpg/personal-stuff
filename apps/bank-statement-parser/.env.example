# Copy to .env and fill in. The service reads these from the environment.

# Required: your Anthropic API key (console.anthropic.com -> API keys).
ANTHROPIC_API_KEY=

# Models (optional overrides). Both default to Haiku for cost; bump the vision
# model to claude-sonnet-4-6 if scanned-statement accuracy needs it.
# PARSER_TEXT_MODEL=claude-haiku-4-5      # digital PDFs (text path)
# PARSER_VISION_MODEL=claude-haiku-4-5    # scanned PDFs and images
# PARSER_MAX_TOKENS=8000                  # output cap per call (bounds cost)

# Behaviour (optional):
# PARSER_MAX_FILE_MB=15
# PARSER_MAX_PAGES=30      # reject statements over this many pages (bounds per-request cost)
# PARSER_CHUNK_PAGES=8     # statements longer than this are split + parsed concurrently
# PARSER_CACHE_SIZE=256    # number of recent results kept in the file-hash cache

# Set in production so only the RapidAPI proxy can call /v1/parse. Leave blank locally.
# RAPIDAPI_PROXY_SECRET=
