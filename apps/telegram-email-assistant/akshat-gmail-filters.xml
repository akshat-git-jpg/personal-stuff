  <!-- 7. Cold "make money" senders — skip inbox + mark read -->
  <entry>
    <category term="filter"></category>
    <title>Filter: Cold marketing senders</title>
    <content></content>
    <apps:property name="hasTheWord" value="from:(growchannels.com OR primalvideo.com OR coursesfast.com)"/>
    <apps:property name="label" value="🗑️ Junk"/>
    <apps:property name="shouldArchive" value="true"/>
    <apps:property name="shouldMarkAsRead" value="true"/>
    <apps:property name="sizeOperator" value="s_sl"/>
    <apps:property name="sizeUnit" value="s_smb"/>
  </entry>

</feed>
