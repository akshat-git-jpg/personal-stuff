# Copy to .env and fill in. Real secrets for the VPS live in repo-root secrets/ (gitignored).

PORT=8787
TZ=Asia/Kolkata

# Session signing secret (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Initial login password. Used only to seed the password hash on first boot.
# After first boot you can change it in Settings; this var is then ignored.
APP_PASSWORD=changeme

# OpenRouter (cheap model for capture parsing)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Google Calendar (read-only).
# Option A (simplest, used here): reuse an existing authorized-user token JSON
# (the personal-stuff google-shared token already has calendar scope + refresh
# token). Just point at the file — no OAuth consent flow needed.
GOOGLE_TOKEN_FILE=/Users/kbtg/codebase/personal stuff/tooling/mcp/google-shared/tokens/kushalbakliwal25@gmail.com.json

# Option B (fallback): in-app OAuth. Create an OAuth client (Web) in Google
# Cloud Console and connect from Settings. Leave GOOGLE_TOKEN_FILE empty to use this.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/google/callback
