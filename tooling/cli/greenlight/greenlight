#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NOTIFY_BIN="$SCRIPT_DIR/../notify/notify"

# --- JSON Envelope from `claude -p` ---
# Text result: .result
# Input tokens: .usage.input_tokens
# Output tokens: .usage.output_tokens
#
# Extraction via python3:
# result=$(echo "$json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("result", ""))')
# ----------------------------------------

function usage() {
  echo "Usage: greenlight <command> [options]" >&2
  echo "Commands:" >&2
  echo "  run --branch <name> [--repo <path>] [--intent \"<text>\"] [--verify \"<cmd>\" ...] [--review] [--skip <stage,stage>] [--no-land] [--reviewer-model sonnet]" >&2
  echo "" >&2
  echo "  Default gate is DETERMINISTIC: rebase -> verify -> lint -> land." >&2
  echo "  --verify \"<cmd>\"  deterministic check run in the worktree (repeatable; non-zero parks). Pass the project" >&2
  echo "                    test command + the brief's verify steps. No --verify means no test gate ran." >&2
  echo "  --review          opt-in LLM code review before verify (parks on high risk / unresolved findings)." >&2
  echo "                    Off by default — deep whole-repo audits belong to the 'improve' skill, not the land gate." >&2
  echo "  stage names for --skip: review, verify, lint" >&2
  echo "  status <run-id>" >&2
  exit 2
}

if [ $# -eq 0 ]; then
  usage
fi

CMD=$1
shift

REPO="."
BRANCH=""
INTENT=""
SKIP=""
NO_LAND=0
REVIEWER_MODEL="sonnet"
REVIEW=0
VERIFY_CMDS=()
RUN_ID=""

case "$CMD" in
  run)
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --branch) BRANCH="$2"; shift 2 ;;
        --repo) REPO="$2"; shift 2 ;;
        --intent) INTENT="$2"; shift 2 ;;
        --skip) SKIP="$2"; shift 2 ;;
        --no-land) NO_LAND=1; shift ;;
        --reviewer-model) REVIEWER_MODEL="$2"; shift 2 ;;
        --review) REVIEW=1; shift ;;
        --verify) VERIFY_CMDS+=("$2"); shift 2 ;;
        *) usage ;;
      esac
    done
    if [ -z "$BRANCH" ]; then
      echo "ERROR: --branch is required" >&2
      usage
    fi
    ;;
  status)
    if [ $# -ne 1 ]; then usage; fi
    RUN_ID="$1"
    ;;
  *)
    usage
    ;;
esac

REPO=$(cd "$REPO" && pwd) || exit 1
if ! git -C "$REPO" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERROR: $REPO is not a git repository" >&2
  exit 1
fi

REPO_TOPLEVEL=$(git -C "$REPO" rev-parse --show-toplevel)

if [ "$CMD" = "status" ]; then
  STATE_DIR="$HOME/kb-scratch/greenlight/$RUN_ID"
  if [ ! -d "$STATE_DIR" ]; then
    echo "ERROR: run $RUN_ID not found" >&2
    exit 1
  fi
  cat "$STATE_DIR/state"
  exit 0
fi

# Run CMD
BRANCH_SLUG=$(echo "$BRANCH" | tr '/' '-' | tr -cd 'a-zA-Z0-9-')
TIMESTAMP=$(date +"%Y%m%d-%H%M")
RUN_ID="${TIMESTAMP}-${BRANCH_SLUG}"
STATE_DIR="$HOME/kb-scratch/greenlight/$RUN_ID"

mkdir -p "$STATE_DIR/evidence"
echo "running" > "$STATE_DIR/state"
touch "$STATE_DIR/log"

function log() {
  echo "[$(date +'%Y-%m-%d %H:%M:%S')] $1" >> "$STATE_DIR/log"
  echo "$1" >&2
}

log "Starting run $RUN_ID for branch $BRANCH"

if [ -z "$INTENT" ]; then
  git -C "$REPO_TOPLEVEL" log --format='%s%n%b' origin/main.."$BRANCH" > "$STATE_DIR/intent.md" || true
else
  echo "$INTENT" > "$STATE_DIR/intent.md"
fi

WT_BIN="wt"

# Acquire worktree
log "Acquiring worktree..."
WT_PATH=$("$WT_BIN" get --repo "$REPO_TOPLEVEL" --holder "greenlight-$RUN_ID")
log "Worktree acquired: $WT_PATH"

function cleanup() {
  log "Releasing worktree..."
  "$WT_BIN" return "$WT_PATH"
}
trap cleanup EXIT

git -C "$WT_PATH" checkout "$BRANCH" >&2 || {
  log "ERROR: failed to checkout branch $BRANCH"
  echo "failed" > "$STATE_DIR/state"
  exit 1
}

function run_agent_stage() {
  local stage=$1
  local prompt_file=$2
  local required_keys=$3
  
  log "Running agent stage: $stage"
  
  local attempt=1
  local prompt_content
  prompt_content=$(cat "$prompt_file")
  local append=""
  
  while [ $attempt -le 2 ]; do
    local full_prompt="$prompt_content$append"
    # Execute claude in worktree
    local claude_out
    if ! claude_out=$(cd "$WT_PATH" && claude -p "$full_prompt" --output-format json --dangerously-skip-permissions --model "$REVIEWER_MODEL" < /dev/null 2>/dev/null); then
      log "ERROR: claude invocation failed on attempt $attempt"
      append="\n\nYour previous reply was not valid JSON matching the schema. Reply with ONLY the JSON object."
      attempt=$((attempt+1))
      continue
    fi
    
    local extracted_json
    extracted_json=$(echo "$claude_out" | python3 -c '
import json, re, sys
from json import JSONDecoder

# Pull the assistant text out of the `claude -p --output-format json` envelope,
# then recover the JSON object it contains. Reviewers routinely wrap their reply
# in a ```json ... ``` fence or add a sentence of preamble; a bare json.load on
# that text throws and the stage falsely reports "missing required keys".
def recover(text):
    text = text.strip()
    m = re.match(r"^```(?:json)?\s*\n?(.*?)\n?```$", text, re.DOTALL)
    if m:
        text = m.group(1).strip()
    try:
        return json.loads(text)
    except Exception:
        pass
    # Fallback: decode the first well-formed JSON value in the text. raw_decode
    # stops at the end of the object, so trailing prose (and braces inside
    # strings) do not fool it.
    dec = JSONDecoder()
    idx = text.find("{")
    while idx != -1:
        try:
            obj, _ = dec.raw_decode(text[idx:])
            return obj
        except ValueError:
            idx = text.find("{", idx + 1)
    return None

try:
    result = json.load(sys.stdin).get("result", "")
except Exception:
    result = ""

obj = recover(result) if result else None
print(json.dumps(obj) if obj is not None else "")
')
    
    if [ -z "$extracted_json" ]; then
      log "ERROR: failed to extract result from envelope on attempt $attempt"
      append="\n\nYour previous reply was not valid JSON matching the schema. Reply with ONLY the JSON object."
      attempt=$((attempt+1))
      continue
    fi
    
    # Validate required keys
    local valid=1
    for key in $(echo "$required_keys" | tr ',' ' '); do
      if ! echo "$extracted_json" | python3 -c "import json,sys; d=json.load(sys.stdin); sys.exit(0 if '$key' in d else 1)" 2>/dev/null; then
        valid=0
        break
      fi
    done
    
    if [ $valid -eq 1 ]; then
      echo "$extracted_json" > "$STATE_DIR/findings-$stage.json"
      return 0
    else
      log "ERROR: extracted JSON missing required keys on attempt $attempt"
      append="\n\nYour previous reply was not valid JSON matching the schema. Reply with ONLY the JSON object."
      attempt=$((attempt+1))
    fi
  done
  
  log "ERROR: agent stage $stage failed after 2 attempts"
  echo "failed" > "$STATE_DIR/state"
  # Notify (Telegram-first, ntfy fallback)
  "$NOTIFY_BIN" send "greenlight: stage $stage failed for $BRANCH" || true
  exit 1
}

log "Run setup complete"

# Check if stage is skipped
function is_skipped() {
  local stage=$1
  if [[ ",$SKIP," == *",$stage,"* ]]; then
    return 0
  else
    return 1
  fi
}

function park() {
  local reason=$1
  log "Parking: $reason"
  echo "parked" > "$STATE_DIR/state"
  echo "$reason" > "$STATE_DIR/parked-reason"
  "$NOTIFY_BIN" send "greenlight: $BRANCH parked — $reason" || true
  exit 0
}

# 1. rebase
if ! is_skipped "rebase"; then
  log "Stage: rebase"
  git -C "$WT_PATH" fetch origin >&2 || true
  if ! git -C "$WT_PATH" rebase origin/main >&2; then
    git -C "$WT_PATH" diff --name-only --diff-filter=U > "$STATE_DIR/findings-rebase.json"
    git -C "$WT_PATH" rebase --abort >&2 || true
    park "rebase conflict"
  fi

  if git -C "$WT_PATH" diff --quiet origin/main..HEAD; then
    log "empty diff — nothing to do"
    echo "landed" > "$STATE_DIR/state"
    exit 0
  fi
fi

risk_level="low"

# 2. review — OPT-IN deep LLM pass, NOT a default gate. Whole-repo LLM auditing
# belongs to the `improve` skill (advisory, non-gating); the land gate below is
# deterministic. --review layers a code-review pass on top for risky diffs.
if [ "$REVIEW" -eq 1 ] && ! is_skipped "review"; then
  log "Stage: review (opt-in)"
  export FINDINGS_JSON=""
  run_agent_stage "review" "$SCRIPT_DIR/prompts/review.md" "findings,risk_level"
  
  risk_level=$(cat "$STATE_DIR/findings-review.json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("risk_level", "low"))')
  if [ "$risk_level" = "high" ]; then
    park "risk_level: high"
  fi
  
  # Auto-fix loop
  for round in 1 2 3; do
    needs_fix=$(cat "$STATE_DIR/findings-review.json" | python3 -c '
import json,sys
try:
  d=json.load(sys.stdin)
  needs = [f for f in d.get("findings", []) if f.get("action") == "auto-fix" and f.get("severity") in ("error", "warning")]
  print("yes" if needs else "no")
except:
  print("no")
')
    if [ "$needs_fix" = "no" ]; then break; fi
    log "Review auto-fix round $round"
    export FINDINGS_JSON=$(cat "$STATE_DIR/findings-review.json")
    run_agent_stage "review-fix" "$SCRIPT_DIR/prompts/review.md" "findings,risk_level"
    mv "$STATE_DIR/findings-review-fix.json" "$STATE_DIR/findings-review.json"
  done
  
  # Check unresolved
  unresolved=$(cat "$STATE_DIR/findings-review.json" | python3 -c '
import json,sys
try:
  d=json.load(sys.stdin)
  unresolved = [f for f in d.get("findings", []) if f.get("action") == "ask-user" or (f.get("action") == "auto-fix" and f.get("severity") in ("error", "warning"))]
  print(len(unresolved))
except:
  print("1")
')
  if [ "$unresolved" != "0" ]; then
    park "$unresolved findings need you"
  fi
fi

# 3. verify — DETERMINISTIC gate. Runs the caller-supplied --verify commands in
# the worktree (the project test command + the brief's verify steps). Any
# non-zero exit parks. This replaces the old LLM-driven "test"/"docs" stages:
# the quality gate is real commands with real exit codes, matching the
# orchestrate model. No LLM in the critical path.
if ! is_skipped "verify"; then
  if [ "${#VERIFY_CMDS[@]}" -eq 0 ]; then
    log "Stage: verify — no --verify commands supplied; no deterministic test gate ran"
  else
    log "Stage: verify (${#VERIFY_CMDS[@]} command(s))"
    for cmd in "${VERIFY_CMDS[@]}"; do
      log "verify: $cmd"
      if ! ( cd "$WT_PATH" && bash -c "$cmd" ) >&2; then
        park "verify failed: $cmd"
      fi
    done
  fi
fi

# 4. lint — DETERMINISTIC syntax check on changed shell / python files.
# A failure parks (no LLM fix round); the crewmate owns fixing its own syntax.
if ! is_skipped "lint"; then
  log "Stage: lint"
  lint_failed=0
  for f in $(git -C "$WT_PATH" diff --name-only origin/main..HEAD); do
    if [[ "$f" == *.sh ]] && [ -f "$WT_PATH/$f" ]; then
      bash -n "$WT_PATH/$f" >&2 || lint_failed=1
    elif [[ "$f" == *.py ]] && [ -f "$WT_PATH/$f" ]; then
      python3 -m py_compile "$WT_PATH/$f" >&2 || lint_failed=1
    fi
  done
  if [ "$lint_failed" -eq 1 ]; then
    park "lint failed"
  fi
fi

# Land
if [ "$NO_LAND" -eq 1 ]; then
  park "--no-land"
fi

if [ -n "$(git -C "$REPO_TOPLEVEL" status --porcelain)" ]; then
  park "main checkout busy"
fi

main_branch=$(git -C "$REPO_TOPLEVEL" rev-parse --abbrev-ref HEAD)
if [ "$main_branch" != "main" ]; then
  park "main checkout busy"
fi

git -C "$REPO_TOPLEVEL" merge --no-ff "$BRANCH" -m "greenlight: land $BRANCH ($RUN_ID)" >&2
git -C "$REPO_TOPLEVEL" push origin main >&2
echo "landed" > "$STATE_DIR/state"
"$NOTIFY_BIN" send "greenlight: $BRANCH landed on main (risk $risk_level)" || true
