#!/usr/bin/env bash
# pp-drive — wrapper that resolves the right Python interpreter, then runs
# the CLI. Mirrors cli/gmail/pp-drive so both Mac and VPS work without
# per-machine config.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$DIR/../.." && pwd)"

# VPS has a shared venv at mcp/.venv (created during cron setup).
# Mac uses system python3 with deps installed there.
if [[ -x "$REPO_ROOT/mcp/.venv/bin/python3" ]]; then
  PYTHON_BIN="$REPO_ROOT/mcp/.venv/bin/python3"
else
  PYTHON_BIN="python3"
fi

exec "$PYTHON_BIN" "$DIR/pp_drive.py" "$@"
