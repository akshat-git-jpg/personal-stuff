#!/bin/bash
set -euo pipefail

function usage() {
  echo "Usage: overnight run --repo <path> --objective \"<text>\" [--max-iterations 10] [--max-tokens 1500000] [--stop-when \"<condition>\"] [--max-consecutive-failures 3]" >&2
  exit 2
}

if [ $# -eq 0 ]; then
  usage
fi

CMD=$1
shift

if [ "$CMD" != "run" ]; then
  usage
fi

REPO=""
OBJECTIVE=""
MAX_ITERATIONS=10
MAX_TOKENS=1500000
STOP_WHEN="none set"
MAX_CONSECUTIVE_FAILURES=3

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    --objective) OBJECTIVE="$2"; shift 2 ;;
    --max-iterations) MAX_ITERATIONS="$2"; shift 2 ;;
    --max-tokens) MAX_TOKENS="$2"; shift 2 ;;
    --stop-when) STOP_WHEN="$2"; shift 2 ;;
    --max-consecutive-failures) MAX_CONSECUTIVE_FAILURES="$2"; shift 2 ;;
    *) usage ;;
  esac
done

if [ -z "$REPO" ] || [ -z "$OBJECTIVE" ]; then
  usage
fi

REPO=$(cd "$REPO" && pwd) || exit 1
if ! git -C "$REPO" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERROR: $REPO is not a git repository" >&2
  exit 1
fi

REPO_TOPLEVEL=$(git -C "$REPO" rev-parse --show-toplevel)

# 1. Run ID and state dir
SLUG=$(echo -n "$OBJECTIVE" | cut -c 1-20 | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/-\+/-/g' | sed 's/-$//')
TIMESTAMP=$(date +"%Y%m%d-%H%M")
RUN_ID="${TIMESTAMP}-${SLUG}"
STATE_DIR="$HOME/kb-scratch/overnight/$RUN_ID"

mkdir -p "$STATE_DIR"
touch "$STATE_DIR/notes.md"
touch "$STATE_DIR/run.log"

function log() {
  echo "[$(date +'%Y-%m-%d %H:%M:%S')] $1" >> "$STATE_DIR/run.log"
  echo "$1"
}

log "Starting overnight run $RUN_ID"

# 2. Acquire worktree
WT_BIN="wt"
log "Acquiring worktree..."
WT_PATH=$("$WT_BIN" get --repo "$REPO_TOPLEVEL" --holder "overnight-$RUN_ID")

HEX6=$(echo "$OBJECTIVE" | shasum -a 256 | cut -c 1-6)
BRANCH="overnight/${SLUG}-${HEX6}"

FINAL_STATE="unknown"
function cleanup() {
  log "Releasing worktree..."
  "$WT_BIN" return "$WT_PATH" || true
  if [ "$FINAL_STATE" != "unknown" ]; then
    echo "$FINAL_STATE" > "$STATE_DIR/state"
  fi
}
trap cleanup EXIT

git -C "$WT_PATH" checkout -b "$BRANCH" >/dev/null 2>&1
git -C "$WT_PATH" rev-parse HEAD > "$STATE_DIR/base-commit"
BASE_COMMIT=$(cat "$STATE_DIR/base-commit")

# 3. Iteration loop
ITERATION=1
TOTAL_TOKENS=0
CONSEC_FAILS=0

while [ $ITERATION -le $MAX_ITERATIONS ]; do
  if [ $TOTAL_TOKENS -ge $MAX_TOKENS ]; then
    FINAL_STATE="token-cap"
    break
  fi
  
  if [ $CONSEC_FAILS -ge $MAX_CONSECUTIVE_FAILURES ]; then
    FINAL_STATE="failed"
    break
  fi

  log "Iteration $ITERATION (Tokens: $TOTAL_TOKENS/$MAX_TOKENS, Fails: $CONSEC_FAILS/$MAX_CONSECUTIVE_FAILURES)"
  
  # Build prompt
  PROMPT_TPL=$(cat "$(dirname "$0")/iteration-prompt.md")
  PROMPT_TEXT="${PROMPT_TPL//\{\{OBJECTIVE\}\}/$OBJECTIVE}"
  PROMPT_TEXT="${PROMPT_TEXT//\{\{ITERATION\}\}/$ITERATION}"
  NOTES_CONTENT=$(cat "$STATE_DIR/notes.md")
  PROMPT_TEXT="${PROMPT_TEXT//\{\{NOTES\}\}/$NOTES_CONTENT}"
  PROMPT_TEXT="${PROMPT_TEXT//\{\{STOP_WHEN\}\}/$STOP_WHEN}"
  
  # Agent attempt
  attempt=1
  append=""
  agent_valid=0
  
  while [ $attempt -le 2 ]; do
    full_prompt="$PROMPT_TEXT$append"
    env_file="$STATE_DIR/iteration-$ITERATION.json"
    
    if ! claude_out=$(cd "$WT_PATH" && claude -p "$full_prompt" --output-format json --dangerously-skip-permissions < /dev/null 2>/dev/null); then
      log "ERROR: claude invocation failed on attempt $attempt"
      append="\n\nYour previous reply was not valid JSON matching the schema. Reply with ONLY the JSON object."
      attempt=$((attempt+1))
      continue
    fi
    
    echo "$claude_out" > "$env_file"
    
    # Parse envelope
    in_tok=$(echo "$claude_out" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("usage", {}).get("input_tokens", 0))' 2>/dev/null || echo 0)
    out_tok=$(echo "$claude_out" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("usage", {}).get("output_tokens", 0))' 2>/dev/null || echo 0)
    TOTAL_TOKENS=$((TOTAL_TOKENS + in_tok + out_tok))
    
    extracted=$(echo "$claude_out" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("result", ""))' 2>/dev/null || true)
    
    if [ -z "$extracted" ]; then
      log "ERROR: failed to extract result from envelope"
      append="\n\nYour previous reply was not valid JSON matching the schema. Reply with ONLY the JSON object."
      attempt=$((attempt+1))
      continue
    fi
    
    # Validate keys
    is_valid=$(echo "$extracted" | python3 -c '
import json,sys
try:
  d=json.load(sys.stdin)
  for k in ["success", "summary", "key_changes", "key_learnings", "should_fully_stop"]:
    if k not in d:
      sys.exit(1)
  sys.exit(0)
except Exception as e:
  print(f"ERROR: {e}")
  sys.exit(1)
' && echo "yes" || echo "no")
    
    if [ "$is_valid" = "yes" ]; then
      agent_valid=1
      echo "$extracted" > "$STATE_DIR/iteration-${ITERATION}-parsed.json"
      break
    else
      log "ERROR: extracted JSON missing required keys"
      append="\n\nYour previous reply was not valid JSON matching the schema. Reply with ONLY the JSON object."
      attempt=$((attempt+1))
    fi
  done
  
  if [ $agent_valid -eq 0 ]; then
    log "Iteration $ITERATION failed to return valid JSON after 2 attempts."
    git -C "$WT_PATH" reset --hard >/dev/null 2>&1
    git -C "$WT_PATH" clean -fd >/dev/null 2>&1
    CONSEC_FAILS=$((CONSEC_FAILS+1))
    echo -e "\n### Iteration $ITERATION [FAIL]\nFailed to parse JSON reply." >> "$STATE_DIR/notes.md"
    ITERATION=$((ITERATION+1))
    continue
  fi
  
  parsed_file="$STATE_DIR/iteration-${ITERATION}-parsed.json"
  success=$(cat "$parsed_file" | python3 -c 'import json,sys; print(str(json.load(sys.stdin).get("success", False)).lower())')
  should_stop=$(cat "$parsed_file" | python3 -c 'import json,sys; print(str(json.load(sys.stdin).get("should_fully_stop", False)).lower())')
  summary=$(cat "$parsed_file" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("summary", ""))')
  changes=$(cat "$parsed_file" | python3 -c 'import json,sys; print("\n".join("- " + c for c in json.load(sys.stdin).get("key_changes", [])))')
  learnings=$(cat "$parsed_file" | python3 -c 'import json,sys; print("\n".join("- " + l for l in json.load(sys.stdin).get("key_learnings", [])))')
  
  if [ "$success" = "true" ]; then
    git -C "$WT_PATH" add -A >/dev/null 2>&1
    if ! git -C "$WT_PATH" commit -m "overnight $ITERATION: $summary" >/dev/null 2>&1; then
      log "Commit failed"
      FINAL_STATE="commit-failed"
      break
    fi
    echo -e "\n### Iteration $ITERATION\n**Summary:** $summary\n**Changes:**\n$changes\n**Learnings:**\n$learnings" >> "$STATE_DIR/notes.md"
    CONSEC_FAILS=0
    
    if [ "$should_stop" = "true" ]; then
      FINAL_STATE="stop-condition-met"
      ITERATION=$((ITERATION+1))
      break
    fi
  else
    git -C "$WT_PATH" reset --hard >/dev/null 2>&1
    git -C "$WT_PATH" clean -fd >/dev/null 2>&1
    CONSEC_FAILS=$((CONSEC_FAILS+1))
    echo -e "\n### Iteration $ITERATION [FAIL]\n**Learnings:**\n$learnings" >> "$STATE_DIR/notes.md"
  fi
  
  ITERATION=$((ITERATION+1))
done

if [ "$FINAL_STATE" = "unknown" ]; then
  if [ $ITERATION -gt $MAX_ITERATIONS ]; then
    FINAL_STATE="iteration-cap"
  fi
fi

# 4. Exit summary
COMMIT_COUNT=$(git -C "$REPO_TOPLEVEL" rev-list --count "${BASE_COMMIT}..${BRANCH}" 2>/dev/null || echo 0)
SUMMARY_MSG="overnight: $FINAL_STATE, $COMMIT_COUNT commits on $BRANCH, $TOTAL_TOKENS tokens"

log "Run completed"
log "State: $FINAL_STATE"
log "Iterations: $((ITERATION-1))"
log "Total tokens: $TOTAL_TOKENS"
log "Commits: $COMMIT_COUNT"
log "Branch: $BRANCH"
log "To review:"
log "  git log --oneline ${BASE_COMMIT}..${BRANCH}"
log "  git diff --stat ${BASE_COMMIT}..${BRANCH}"

pp-ntfy send "$SUMMARY_MSG" || true
