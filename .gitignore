# Secrets — never commit these
secrets/
**/.env
**/credentials.json
**/token.json
**/token_*.json
**/service_account.json
**/google-shared/tokens/

# Local MCP config — paths inside are absolute to this machine, so
# committing would break other clones. Each machine generates its own
# from ~/.claude-personal/.claude.json's mcpServers block.
.mcp.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
*.egg-info/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Local Claude permission overrides (each project may keep its own)
# NOTE: project .claude/settings.local.json is allowed (per-project overrides),
# only ignore stray runtime files
.claude/cache/
.claude/logs/

# Backup files from edits
*.bak
*.bak-*

# Build / coverage artifacts (in case any of the MCPs ever grow these)
build/
dist/
.coverage
htmlcov/
.pytest_cache/

# IDE
.idea/
.vscode/

# ntfy runtime data — caches, attachments, user db (server.yml is checked in)
infra/docker/ntfy/data/cache/
infra/docker/ntfy/data/etc/users.db

# Rendered/generated media — outputs are rebuildable, never commit
pipelines/video/voice/**/output/
pipelines/hyperframes-vs-remotion/yt-visuals/cutaways/**/*.mp4
pipelines/hyperframes-vs-remotion/yt-visuals/cutaways/**/*.webm
docs/voice-pipeline-test/

# Node dependencies — never commit
node_modules/

# secrets escrow — never commit archives (script writes to TMPDIR, this is a guard)
infra/escrow/*.gpg
infra/escrow/*.tar.gz
infra/escrow/out/
