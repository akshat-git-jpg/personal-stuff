#!/usr/bin/env bash
# pp-rapidapi — wrapper that resolves the right Python interpreter, then runs
# the CLI. Mirrors cli/youtube/pp-youtube so both Mac and VPS work without
# per-machine config.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$DIR/../.." && pwd)"

if [[ -x "$REPO_ROOT/mcp/.venv/bin/python3" ]]; then
  PYTHON_BIN="$REPO_ROOT/mcp/.venv/bin/python3"
else
  PYTHON_BIN="python3"
fi

exec "$PYTHON_BIN" "$DIR/pp_rapidapi.py" "$@"
