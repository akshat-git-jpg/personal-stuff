{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keto-kitchen",
  "compatibility_date": "2025-01-01",
  // Static-only landing page: no Worker script, just serve the files in ./public
  "assets": {
    "directory": "./public"
  },
  // Attaches the page to its own subdomain with automatic HTTPS.
  "routes": [{ "pattern": "keto-kitchen.agrolloo.com", "custom_domain": true }]
}
