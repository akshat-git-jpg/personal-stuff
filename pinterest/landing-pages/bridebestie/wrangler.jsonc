{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bridebestie",
  "compatibility_date": "2025-01-01",
  // Static-only landing page: no Worker script, just serve the files in ./public
  "assets": {
    "directory": "./public"
  },
  // Apex + www on the brand's own Cloudflare zone, with automatic HTTPS.
  "routes": [
    { "pattern": "bridebestie.com", "custom_domain": true },
    { "pattern": "www.bridebestie.com", "custom_domain": true }
  ]
}
